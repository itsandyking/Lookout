# Firecrawl local stack — copy to .env and edit as needed

# Port to expose the Firecrawl API on the host
# FIRECRAWL_PORT=3002

# Number of worker processes per Bull queue
# NUM_WORKERS=2

# Proxy configuration (optional)
# PROXY_SERVER=http://proxy.example.com:8080
# PROXY_USERNAME=myuser
# PROXY_PASSWORD=mypassword

# Block media (images, fonts, etc.) to speed up scraping
# BLOCK_MEDIA=true

# Auth key for Bull Board queue dashboard
# BULL_AUTH_KEY=lookout-local
